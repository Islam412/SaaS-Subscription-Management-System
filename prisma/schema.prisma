generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== TENANT (الشركة) =====================
model Tenant {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users           User[]           @relation("UserTenant")
  customers       Customer[]       @relation("CustomerTenant")
  subscriptionPlans SubscriptionPlan[] @relation("PlanTenant")
  subscriptions   Subscription[]   @relation("SubscriptionTenant")
  invoices        Invoice[]        @relation("InvoiceTenant")
  payments        Payment[]        @relation("PaymentTenant")
  accounts        Account[]        @relation("AccountTenant")
  journalEntries  JournalEntry[]   @relation("JournalEntryTenant")

  @@map("tenants")
}

// ===================== USER (مستخدم النظام) =====================
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // hashed
  role      Role     @default(ADMIN)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign Keys
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation("UserTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([email, tenantId])
  @@map("users")
}

enum Role {
  ADMIN
  STAFF
}

// ===================== CUSTOMER (عميل الشركة) =====================
model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  address   String?
  taxId     String?  @map("tax_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign Keys
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation("CustomerTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  subscriptions Subscription[]

  @@unique([email, tenantId])
  @@map("customers")
}

// ===================== SUBSCRIPTION PLAN (خطة الاشتراك) =====================
model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  currency     String   @default("USD")
  billingCycle BillingCycle @default(MONTHLY)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Foreign Keys
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation("PlanTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  subscriptions Subscription[]

  @@unique([name, tenantId])
  @@map("subscription_plans")
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

// ===================== SUBSCRIPTION (اشتراك العميل) =====================
model Subscription {
  id         String   @id @default(uuid())
  startDate  DateTime @map("start_date") @default(now())
  endDate    DateTime? @map("end_date")
  status     SubscriptionStatus @default(ACTIVE)
  autoRenew  Boolean  @default(true) @map("auto_renew")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Foreign Keys
  customerId   String   @map("customer_id")
  planId       String   @map("plan_id")
  tenantId     String   @map("tenant_id")

  // Relations
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  plan       SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation("SubscriptionTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  invoices   Invoice[]

  @@unique([customerId, planId, startDate])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAUSED
}

// ===================== INVOICE (الفاتورة) =====================
model Invoice {
  id          String   @id @default(uuid())
  invoiceNumber String @unique @map("invoice_number")
  amount      Decimal  @db.Decimal(10, 2)
  tax         Decimal? @db.Decimal(10, 2) @default(0)
  totalAmount Decimal  @map("total_amount") @db.Decimal(10, 2)
  currency    String   @default("USD")
  status      InvoiceStatus @default(DRAFT)
  invoiceDate DateTime @map("invoice_date") @default(now())
  dueDate     DateTime @map("due_date")
  paidAt      DateTime? @map("paid_at")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Foreign Keys
  subscriptionId String @map("subscription_id")
  tenantId       String @map("tenant_id")

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  tenant       Tenant     @relation("InvoiceTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  payment      Payment?

  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

// ===================== PAYMENT (الدفعة) =====================
model Payment {
  id          String   @id @default(uuid())
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  paymentDate DateTime @map("payment_date") @default(now())
  method      PaymentMethod @default(CASH)
  reference   String?
  status      PaymentStatus @default(COMPLETED)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Foreign Keys
  invoiceId  String   @unique @map("invoice_id")
  tenantId   String   @map("tenant_id")

  // Relations
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation("PaymentTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  // Accounting
  journalEntryId String? @unique @map("journal_entry_id")
  journalEntry JournalEntry? @relation("PaymentJournalEntry", fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@map("payments")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  PAYPAL
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ===================== ACCOUNTING (المحاسبة) =====================

// دليل الحسابات
model Account {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  type        AccountType
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Foreign Keys
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation("AccountTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  journalLines JournalLine[]

  @@unique([code, tenantId])
  @@map("accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

// القيد المحاسبي
model JournalEntry {
  id          String   @id @default(uuid())
  entryDate   DateTime @map("entry_date") @default(now())
  description String
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Foreign Keys
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation("JournalEntryTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  lines       JournalLine[]
  payment     Payment? @relation("PaymentJournalEntry")

  @@map("journal_entries")
}

// تفاصيل القيد (Double Entry)
model JournalLine {
  id          String   @id @default(uuid())
  type        JournalLineType
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  // Foreign Keys
  journalEntryId String @map("journal_entry_id")
  accountId      String @map("account_id")

  // Relations
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("journal_lines")
}

enum JournalLineType {
  DEBIT
  CREDIT
}